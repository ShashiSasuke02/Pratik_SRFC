generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String
  mobile    String
  service   String
  message   String
  createdAt DateTime @default(now())
}
