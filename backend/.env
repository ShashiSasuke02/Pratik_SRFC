DATABASE_URL="file:./dev.db"
PORT=5000

# Master switch: set to "gmail" or "brevo"
EMAIL_PROVIDER=gmail

# Gmail configuration
EMAIL_USER=auditsrfc@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Brevo (Sendinblue) configuration
# Get your SMTP key from: https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_USER=your_brevo_login_email@example.com
BREVO_SMTP_KEY=your_brevo_smtp_key_here

# The email address that will appear as the sender
EMAIL_FROM_ADDRESS=auditsrfc@gmail.com
# The email address that will RECEIVE the contact form notifications
EMAIL_TO_ADDRESS=auditsrfc@gmail.com
